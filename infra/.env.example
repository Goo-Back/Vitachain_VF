# Copy to infra/.env and fill in. NEVER commit infra/.env.
# Consumed by deploy.sh, verify.sh, issue-cert.sh, and renew-cert.sh.

# Host the deploy targets — set to the bare domain once DNS is live, or the IP before that.
VPS_HOST=vitachain.ma

# Linux account created by bootstrap-vps.sh
VPS_USER=vitachain

# Remote install location (must match bootstrap-vps.sh)
PROJECT_DIR=/opt/vitachain

# Extra ssh options if you keep a non-default key
# SSH_OPTS=-i ~/.ssh/vitachain_ed25519 -o StrictHostKeyChecking=accept-new

# -----------------------------------------------------------------------------
# INF-03 — Public Supabase values consumed by docker-compose to build the
# frontend image. Copy from the root .env (filled in INF-02). Only NEXT_PUBLIC_*
# may appear here. Service-role / JWT secrets stay backend-only (INF-04 / AUTH-05).
#
# NOTE: NEXT_PUBLIC_SITE_URL is INLINED into the JS bundle at build time.
# Changing it requires `make -C infra frontend-rebuild`, not just a redeploy.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://vitachain.ma

# -----------------------------------------------------------------------------
# INF-04 — FastAPI backend runtime env. These NEVER leave the backend
# container (AUTH-05 — verified by infra/scripts/verify.sh).
# -----------------------------------------------------------------------------
ENVIRONMENT=prod
LOG_LEVEL=INFO
GIT_SHA=unknown
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AUTH-03 — JWT validation secret (HS256, 256-bit minimum).
#   Source: Dashboard → Settings → API → JWT Secret.
#   Bitwarden: "VitaChain — Supabase JWT secret".
#   IMPORTANT: this is the *signing* secret used to VALIDATE user tokens.
#              It is NOT the service-role key and does NOT bypass RLS.
#              Must be ≥ 64 hex characters (32 bytes / 256 bits).
#              Never commit a real value.
SUPABASE_JWT_SECRET=
# Comma-separated list. Both apex and www must be allow-listed once INF-06
# flips the site to HTTPS, otherwise browsers reject server-action POSTs.
CORS_ALLOW_ORIGINS=https://vitachain.ma,https://www.vitachain.ma
WEB_CONCURRENCY=2

# -----------------------------------------------------------------------------
# INF-06 — Let's Encrypt / Certbot
#
# ADMIN_EMAIL is the ACME account contact. Let's Encrypt sends:
#   * 20-days-before-expiry warnings if renewal hasn't happened yet
#   * Failure notifications on the day a renewal attempt errors
# Use a MONITORED inbox — if this address is unread, the demo gets a red
# padlock and no one notices until a user complains.
ADMIN_EMAIL=ops@vitachain.ma

# Space-separated list. The first entry is the primary domain (the
# /etc/letsencrypt/live/<primary>/ directory name and the --cert-name).
# Adding a subdomain later is a one-line edit + re-run of issue-cert.sh.
DOMAINS=vitachain.ma www.vitachain.ma

# Optional — Healthchecks.io UUID for renewal heartbeat (INF-07 pattern).
# If set, renew-cert.sh pings this URL on every successful run; HC alerts
# us when no ping arrives for >3 days, well before the 30-day expiry cliff.
# HEALTHCHECKS_RENEW_URL=https://hc-ping.com/<uuid>

# -----------------------------------------------------------------------------
# INF-07 — Nightly DB backup to Backblaze B2.
#
# SUPABASE_DB_URL — DIRECT Postgres URL (:5432), NOT the pooler (:6543).
#   Source: Bitwarden → "VitaChain — Supabase DB direct URL".
#   Format: postgresql://postgres:<PASS>@db.<ref>.supabase.co:5432/postgres
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=

# Backblaze B2 — credentials live in the rclone_config volume after the
# one-shot `make -C infra backup-rclone-config` ceremony. These four are
# convenience knobs for the entrypoint; only the bucket name is sensitive
# (and only mildly — bucket discovery without a key is not exploitable).
BACKUP_BUCKET=vitachain-backups
BACKUP_REMOTE_PATH=postgres
BACKUP_RETENTION_LOCAL_DAYS=7
BACKUP_RETENTION_REMOTE_DAYS=30

# Healthchecks.io — paste the ping URL from the dashboard for the check
# named "vitachain-db-backup". The check schedule there must be
# `0 2 * * *` (Africa/Casablanca) with a 60-minute grace window.
#   Source: Bitwarden → "VitaChain — Healthchecks backup URL".
HEALTHCHECKS_BACKUP_URL=

# Alert webhook — Discord / Telegram / Slack incoming-webhook URL.
# Posted into a chat the team reads when a backup fails. JSON shape in
# backup-db.sh is Discord-flavoured; tweak `post_alert()` if using Slack
# or Telegram. Empty value disables the alert (heartbeat alert via
# Healthchecks is the floor).
ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# INF-08 — Sentry + Uptime Kuma observability
#
# Two DSNs (same Sentry project, different Client Keys). The split lets the
# AUTH-05 boundary script enforce `SENTRY_DSN_BACKEND` never appearing in
# frontend/ with the same grep convention it already uses for service-role
# keys. The frontend DSN is INLINED into the JS bundle at BUILD time — see
# docker-compose.yml `args:` block — so a change requires
# `make -C infra frontend-rebuild`, not just a redeploy.
#
# SENTRY_AUTH_TOKEN is CI-only — used to upload source maps from a GitHub
# Actions runner. NEVER paste it on the VPS .env. The variable is left out
# of this example file on purpose; CI's environment supplies it.
#   Source: Bitwarden → "VitaChain — Sentry DSN (backend|frontend)",
#           "VitaChain — Sentry CI auth token".
# -----------------------------------------------------------------------------
SENTRY_DSN_BACKEND=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1

# Uptime Kuma admin gate (NGINX basic-auth on /uptime/).
#   * USER is plain (typed at curl/browser).
#   * PASSWORD_HASH is the bcrypt portion AFTER the colon in `htpasswd -nbB`.
# Generate with: make -C infra observability-htpasswd USER=admin PASS='...'
# Save the plain password in Bitwarden as "VitaChain — Uptime Kuma admin".
UPTIME_KUMA_ADMIN_USER=admin
UPTIME_KUMA_ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# AUTH-08 — NGINX rate limiting on public endpoints
#
# VPS_PUBLIC_IP is the egress IP the VPS itself uses when making outbound
# calls (Uptime Kuma monitor probes hitting /healthz, Next.js SSR fallback
# calls to /api/v1/*). It is whitelisted in the `geo $ratelimit_whitelist`
# block so monitoring traffic never trips its own bucket. Find it with:
#   ssh $VPS_USER@$VPS_HOST 'curl -s ifconfig.me'
VPS_PUBLIC_IP=
#
# RATELIMIT_WHITELIST_IPS — comma-separated extra IPs / CIDRs that bypass
# per-IP rate limits. Use for demo-day field laptops and on-call workstations.
# Operator-supplied entries are expanded by deploy.sh into NGINX `<ip> 1;`
# lines and substituted into 00-rate-limits.conf.template at container boot.
# Format: dotted-quad IPs (or CIDR), comma-separated, no spaces required.
# Example: RATELIMIT_WHITELIST_IPS=203.0.113.5,198.51.100.0/24
# The auth_* and iot_ingest zones DELIBERATELY do not exempt the whitelist —
# operator brute force is still brute force.
RATELIMIT_WHITELIST_IPS=

# -----------------------------------------------------------------------------
# KAT-06 — Threshold-crossing email alert worker.
#
# BREVO_API_KEY — full-send Brevo transactional API key (NOT the read-only
# probe key below). Used by backend/app/workers/mailer.py for ALL system
# emails. Source: Bitwarden → "VitaChain — Brevo transactional API key".
BREVO_API_KEY=
BREVO_SENDER_NAME=VitaChain
BREVO_SENDER_EMAIL=no-reply@vitachain.ma

# Numeric Brevo template ids. Create in the Brevo dashboard from the mirrors
# under infra/brevo-templates/kat06_threshold_alert/{fr,ar,en}.html.
# Empty values disable that locale — the worker falls back to `fr` per PRD §7.2.
BREVO_TEMPLATE_KAT_THRESHOLD_FR=1
BREVO_TEMPLATE_KAT_THRESHOLD_AR=2
BREVO_TEMPLATE_KAT_THRESHOLD_EN=3

# Dashboard deep-link base for the email CTA. Defaults to https://vitachain.ma.
FRONTEND_BASE_URL=https://vitachain.ma

# Healthchecks.io ping URL for the worker's 60 s heartbeat. A 5-minute silence
# pages on-call via the Uptime Kuma → Brevo bridge (INF-08).
#   Source: Bitwarden → "VitaChain — Healthchecks katara-threshold URL".
HEALTHCHECKS_KAT_THRESHOLD_PING_URL=

# Read-only Brevo API key used by the Brevo upstream Kuma monitor. SCOPED in
# the Brevo dashboard to "Get account info" ONLY — cannot send mail or read
# logs. Separate from the backend's send-email key so a Kuma compromise can
# never abuse the team's email reputation.
#   Source: Bitwarden → "VitaChain — Brevo readonly probe key".
UPTIME_KUMA_BREVO_API_KEY=

# -----------------------------------------------------------------------------
# KAT-08 — AI diagnostic worker (OWM + Sentinel-2 NDVI + 7d sensor avg + Gemini)
#
# All four credentials are free-tier. Numbers below are vendor quotas at the
# date of issue (2026-05-17) — re-check before flipping to Pro tiers.
# -----------------------------------------------------------------------------
# OpenWeatherMap — /data/2.5/forecast. Free tier: 60 calls/min, 1 M calls/month.
# BR-K3 cache (3 h TTL on m1_katara_owm_cache, lat/lng quantised to 0.01°)
# keeps us at < 1% of monthly quota at MVD scale.
#   Source: Bitwarden → "VitaChain — OpenWeatherMap API key".
OPENWEATHERMAP_API_KEY=

# Sentinel Hub — OAuth client-credentials. Free tier: 30 K processing units / month.
# Each NDVI Process API call ≈ 4 PU; BR-K7 12 h cache + BR-K6 3/parcel/24h cap
# keeps us at ~10% in the worst case.
#   Source: Bitwarden → "VitaChain — Sentinel Hub OAuth (client_id, client_secret)".
SENTINEL_HUB_API_KEY=

# Gemini — google-generativeai SDK against gemini-1.5-flash. Free tier:
# 1.5 K req/day, 1 M-token context (PRD §11.1). Override GEMINI_MODEL to
# gemini-1.5-flash-8b or gemini-1.5-pro after demo-day if quality measurement
# justifies the spend.
#   Source: Bitwarden → "VitaChain — Gemini API key".
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Healthchecks.io ping URL for the diagnostic worker's 60 s heartbeat. A
# 5-minute silence pages on-call via the Uptime Kuma → Brevo bridge (INF-08).
#   Source: Bitwarden → "VitaChain — Healthchecks katara-diagnostic URL".
HEALTHCHECKS_KAT_DIAGNOSTIC_PING_URL=

# -----------------------------------------------------------------------------
# KAT-09 — Diagnostic completion email worker (Brevo on COMPLETED).
#
# Numeric Brevo template ids. Create in the Brevo dashboard from the mirrors
# under infra/brevo-templates/kat09_diagnostic_completion/{fr,ar,en}.html.
# Empty values disable that locale — the worker falls back to `fr` per PRD §7.2.
# Until I18N-06 ships the populated AR/EN content, AR and EN can temporarily
# point to the FR template id.
#   Source: Bitwarden → "VitaChain — Brevo template ids".
BREVO_TEMPLATE_KAT_DIAGNOSTIC_FR=4
BREVO_TEMPLATE_KAT_DIAGNOSTIC_AR=5
BREVO_TEMPLATE_KAT_DIAGNOSTIC_EN=6

# Healthchecks.io ping URL for the diagnostic-email worker's 60 s heartbeat.
# A 5-minute silence pages on-call via the Uptime Kuma → Brevo bridge (INF-08).
#   Source: Bitwarden → "VitaChain — Healthchecks katara-diagnostic-email URL".
HEALTHCHECKS_KAT_DIAGNOSTIC_EMAIL_PING_URL=

# -----------------------------------------------------------------------------
# KAT-11 — Offline-device detection worker (Brevo on > 1 h ESP32 silence).
#
# Numeric Brevo template ids. Create in the Brevo dashboard from the mirrors
# under infra/brevo-templates/kat11_offline_alert/{fr,ar,en}.html. Empty
# values disable that locale — the worker falls back to `fr` per PRD §7.2.
# Until I18N-06 ships the populated AR/EN content, AR and EN can temporarily
# point to the FR template id.
#   Source: Bitwarden → "VitaChain — Brevo template ids".
BREVO_TEMPLATE_KAT_OFFLINE_FR=7
BREVO_TEMPLATE_KAT_OFFLINE_AR=8
BREVO_TEMPLATE_KAT_OFFLINE_EN=9

# Healthchecks.io ping URL for the offline-detection worker's 60 s heartbeat.
# A 5-minute silence pages on-call via the Uptime Kuma → Brevo bridge (INF-08).
#   Source: Bitwarden → "VitaChain — Healthchecks katara-offline URL".
HEALTHCHECKS_KAT_OFFLINE_PING_URL=

# -----------------------------------------------------------------------------
# FAR-04 — FarMarket lead-email worker (Brevo email to seller on new lead).
#
# Numeric Brevo template IDs (integers from the Brevo dashboard).
# FR is mandatory (P0 locale, PRD §7.2). AR and EN can be 0 until I18N-06.
# BR-F4: these keys live in the backend worker env only — never in frontend.
#   Source: Bitwarden → "VitaChain — Brevo template ids".
# -----------------------------------------------------------------------------
# FAR-04 (rewritten) — anonymised order notification to producer. The old
# FAR-03/04 lead-email envs (BREVO_TEMPLATE_FAR_LEAD_*, HEALTHCHECKS_FAR_LEAD_*)
# were removed with migration 0039.
BREVO_TEMPLATE_FAR_ORDER_FR=
BREVO_TEMPLATE_FAR_ORDER_AR=0
BREVO_TEMPLATE_FAR_ORDER_EN=0

# Heartbeat URL for the farmarket-order-notify worker's 60 s heartbeat.
# A 5-minute silence pages on-call via the Uptime Kuma → Brevo bridge (INF-08).
#   Source: Bitwarden → "VitaChain — Healthchecks farmarket-order-notify URL".
HEALTHCHECKS_FAR_ORDER_NOTIFY_PING_URL=

# -----------------------------------------------------------------------------
# FAR-06 — nightly ad expiry worker
# Healthchecks.io ping URL — create a new check named "farmarket_expiry" with
# schedule "0 3 * * *" and a 26h grace period (covers a full 24h cycle + 2h slack).
# Leave blank to disable the ping (worker still runs; silence detection disabled).
HEALTHCHECKS_FAR_EXPIRY_PING_URL=
# Override scan period for local dev/testing. Default 86400 (24 h).
# Set to 300 (5 min) to see expiry fire quickly in dev.
EXPIRY_SCAN_PERIOD_S=86400

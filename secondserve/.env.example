# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudinary (unsigned image uploads).
VITE_CLOUDINARY_CLOUD_NAME="MY_CLOUDINARY_CLOUD_NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="MY_UNSIGNED_PRESET"

# Supabase — shared VitaChain project. Public anon key only (never service_role).
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# VitaChain base URL — used for "back to VitaChain" links and post-logout redirect.
VITE_VITACHAIN_URL="http://localhost:3000"

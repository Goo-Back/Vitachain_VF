# =============================================================================
# VitaChain — root .env template
# =============================================================================
# Copy to .env (git-ignored) and fill from Bitwarden. Owning story: INF-02.
# Frontend variables MUST start with NEXT_PUBLIC_ — anything else is forbidden
# in the Next.js bundle by INF-05 CI.
# =============================================================================

# --- Public (frontend bundle, safe to ship) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://vitachain.ma

# --- Backend only — must NEVER reach the browser (AUTH-05) ------------------
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_PASSWORD=

# Direct Postgres connection (FastAPI workers, migrations runner).
# Format: postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
DB_URL=

# --- Third-party (added by later stories; declared here for visibility) -----
BREVO_API_KEY=              # NOT-01
OPENWEATHERMAP_API_KEY=     # KAT-08
SENTINEL_HUB_API_KEY=       # KAT-08
GEMINI_API_KEY=             # KAT-08

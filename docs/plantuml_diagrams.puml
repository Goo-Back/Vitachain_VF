@startuml fig2_6_classes
' Fig 2.6 — Diagramme de classes simplifié
' Export PNG → figures/fig2_6_classes.png
' ─────────────────────────────────────────────
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #EFF6FF
skinparam classBorderColor #2563EB
skinparam ArrowColor #475569
hide empty members

class Profile {
  +id : UUID
  +role : UserRole
  +verification_status : VerStatus
  +full_name : String
  +phone : String
}

class KycDocument {
  +id : UUID
  +user_id : UUID
  +type : DocType
  +storage_path : String
  +status : String
}

class Parcel {
  +id : UUID
  +farmer_id : UUID
  +name : String
  +crop_type : String
  +surface_area_ha : Decimal
}

class Device {
  +id : UUID
  +device_id : String
  +parcel_id : UUID
  +api_key_hash : String
  +status : DeviceStatus
  +last_seen : Timestamp
}

class TelemetryReading {
  +id : UUID
  +device_id : String
  +soil_moisture : Decimal
  +soil_temperature : Decimal
  +soil_ph : Decimal
  +soil_conductivity : Decimal
  +battery_level : Decimal
  +recorded_at : Timestamp
}

class AlertThreshold {
  +id : UUID
  +parcel_id : UUID
  +metric : String
  +min_value : Decimal
  +max_value : Decimal
}

class AiDiagnostic {
  +id : UUID
  +parcel_id : UUID
  +status : DiagStatus
  +diagnostic_summary : Text
}

class FarmarketAd {
  +id : UUID
  +farmer_id : UUID
  +title : String
  +product_type : String
  +price_mad : Decimal
  +quantity_kg : Decimal
  +status : AdStatus
}

class FarmarketOrder {
  +id : UUID
  +restaurant_id : UUID
  +status : OrderStatus
  +total_mad : Decimal
  +payment_method : String
}

class OrderItem {
  +id : UUID
  +order_id : UUID
  +ad_id : UUID
  +quantity_kg : Decimal
  +line_total_mad : Decimal
  +status : ItemStatus
}

class FarmerRating {
  +id : UUID
  +farmer_id : UUID
  +restaurant_id : UUID
  +rating : Integer
  +review : Text
}

Profile        "1" --> "0..*" KycDocument    : soumet >
Profile        "1" --> "0..*" Parcel         : possède >
Parcel         "1" --> "0..*" Device         : associe >
Device         "1" --> "0..*" TelemetryReading : génère >
Parcel         "1" --> "0..*" AlertThreshold : configure >
Parcel         "1" --> "0..*" AiDiagnostic   : requiert >
Profile        "1" --> "0..*" FarmarketAd    : publie >
Profile        "1" --> "0..*" FarmarketOrder : passe >
FarmarketOrder "1" --> "1..*" OrderItem      : contient >
FarmarketAd    "1" --> "0..*" OrderItem      : référencé par >
Profile        "1" --> "0..*" FarmerRating   : reçoit >
@enduml


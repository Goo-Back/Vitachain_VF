@startuml fig3_5_archi_cloud
' Fig 3.5 — Architecture Cloud VitaChain
' Export PNG → figures/fig3_5_archi_cloud.png
' ─────────────────────────────────────────────
skinparam backgroundColor #FEFEFE
skinparam component {
  BackgroundColor #EFF6FF
  BorderColor     #2563EB
}
skinparam ArrowColor #475569
skinparam nodeBackgroundColor #F8FAFC
skinparam nodeBorderColor #CBD5E1

node "VPS Linux\n(Ubuntu 24.04)" as vps {
  component "NGINX 1.27\n(Reverse Proxy · TLS 1.3)" as nginx
  component "Next.js 15\n(Frontend SSR)"             as fe
  component "FastAPI\n(Backend REST)"                as be
  component "Workers\n(LISTEN/NOTIFY)"               as workers
  component "Uptime Kuma"                            as kuma
}

cloud "Supabase Cloud" as supabase {
  database "PostgreSQL 17\n+ RLS + 50 migrations" as pg
  component "Auth (JWT · Magic Link)"              as auth
  storage   "Storage (S3)"                         as s3
}

cloud "APIs Externes" as ext {
  component "OpenWeatherMap"  as owm
  component "Sentinel-2 Hub\n(OAuth2)"      as sentinel
  component "Google Gemini\n(Flash 1.5)"    as gemini
  component "Brevo\n(E-mails transac.)"     as brevo
}

cloud "Backblaze B2\n(Backups nuit)" as b2
cloud "Sentry\n(Erreurs APM)"       as sentry

nginx    --> fe
nginx    --> be
be       --> pg
be       --> auth
be       --> s3
be       --> owm      : météo
be       --> sentinel : NDVI
workers  --> gemini   : diagnostics IA
workers  --> brevo    : notifications
workers  --> pg       : LISTEN/NOTIFY
be       --> sentry   : erreurs
fe       --> sentry   : erreurs
workers  --> b2       : dumps nocturnels
@enduml


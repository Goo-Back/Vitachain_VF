  EndColor        #1D4ED8
}

start
:Product Backlog\n(50+ User Stories — 5 modules);

repeat
  :Sprint Planning\n(2 semaines — sélection US);
  :Développement\nFastAPI · Next.js · Tests unitaires;
  :Code Review\nGitHub Actions CI — 5 jobs;

# db/.env — copy this file to db/.env and fill from Bitwarden.
# db/.env is git-ignored. Never commit real values.

# Direct Postgres connection string used by `make push` / `make psql`.
# Format: postgresql://postgres:<DB_PASSWORD>@db.<ref>.supabase.co:5432/postgres
# Source: Bitwarden → "VitaChain — Supabase DB password" + project ref.
DB_URL=

# REST endpoint + anon key, used by smoke-signup.sh.
# Source: Bitwarden → "VitaChain — Supabase URL" / "Supabase anon key".
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role JWT — used by smoke-signup.sh to clean up its test user.
# NEVER export this to any frontend env. Source: Bitwarden.
SUPABASE_SERVICE_ROLE_KEY=

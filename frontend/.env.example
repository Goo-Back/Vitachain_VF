# =============================================================================
# VitaChain frontend — public env only (INF-03).
# =============================================================================
# Copy to .env.local locally; on the VPS the values come from /opt/vitachain/.env
# via docker-compose build args.
#
# RULE (AUTH-05): only variables prefixed NEXT_PUBLIC_ may appear here.
# Anything else (service_role key, JWT secret, DB password) is BACKEND-ONLY
# and lives in the FastAPI container's env (INF-04). INF-05 grep-fails the
# build if a forbidden symbol is referenced from frontend/.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://vitachain.ma

# FastAPI backend origin. Server actions proxy to ${NEXT_PUBLIC_API_URL}/api/v1/*
# (parcels, weather, NDVI, farmarket…). Falls back to http://localhost:8000 when
# unset, so local dev works only if the backend listens there; set the deployed
# API origin in prod.
NEXT_PUBLIC_API_URL=http://localhost:8000

# SecondServe (separate Vite app, shared Supabase auth pool). External link
# target for the "Accéder à SecondServe" buttons. Defaults to the Vite dev
# server when unset; set to the deployed origin in prod (e.g. https://secondserve.ma).
NEXT_PUBLIC_SECONDSERVE_URL=http://localhost:5173

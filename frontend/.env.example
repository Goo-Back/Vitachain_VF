# =============================================================================
# VitaChain frontend — public env only (INF-03).
# =============================================================================
# Copy to .env.local locally; on the VPS the values come from /opt/vitachain/.env
# via docker-compose build args.
#
# RULE (AUTH-05): only variables prefixed NEXT_PUBLIC_ may appear here.
# Anything else (service_role key, JWT secret, DB password) is BACKEND-ONLY
# and lives in the FastAPI container's env (INF-04). INF-05 grep-fails the
# build if a forbidden symbol is referenced from frontend/.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://vitachain.ma
